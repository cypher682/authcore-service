# App
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-long-random-secret
APP_TITLE=authcore-service
APP_VERSION=1.0.0
APP_DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://authcore:authcore_pass@localhost:5432/authcore_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_CHALLENGE_EXPIRE_MINUTES=5
JWT_ALGORITHM=HS256

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Email (placeholder — Celery task will use this)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=noreply@authcore.dev

# Sentry (leave blank in dev)
SENTRY_DSN=

# HaveIBeenPwned
HIBP_API_KEY=

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_SENSITIVE=5/minute

# Session
MAX_CONCURRENT_SESSIONS=5
SESSION_EXPIRE_DAYS=30

# Lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_TTL_SECONDS=900
